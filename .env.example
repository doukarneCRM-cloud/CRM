# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/anaqatoki"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ─────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# ─── Youcan Integration ──────────────────────────────────────
YOUCAN_WEBHOOK_SECRET="your_youcan_webhook_secret"

# ─── Coliix Integration ──────────────────────────────────────
COLIIX_API_KEY="your_coliix_api_key"
COLIIX_BASE_URL="https://api.coliix.com"

# ─── Cloudflare R2 (uploads) ─────────────────────────────────
# All five must be set to use R2. If any is missing, uploads fall back to
# the local `uploads/` folder (dev-only — do NOT rely on this in production).
R2_ENDPOINT=""              # e.g. https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=""                # e.g. anaqatoki-uploads
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL=""            # e.g. https://pub-xxxx.r2.dev (or your custom domain)

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL="http://localhost:3001"
VITE_SOCKET_URL="http://localhost:3001"
