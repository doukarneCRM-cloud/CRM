{
  "name": "@anaqatoki/backend",
  "version": "1.0.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/index.ts\"",
    "build": "tsc",
    "start": "npx prisma migrate deploy && node dist/index.js",
    "migrate": "npx prisma migrate deploy && node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node -r tsconfig-paths/register src/prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register src/prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "dotenv": "^17.4.2",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^3.15.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "nodemon": "^3.1.1",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
