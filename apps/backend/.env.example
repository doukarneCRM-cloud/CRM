# ─── Backend environment ─────────────────────────────────────────────────────
# Copy to .env for local dev. In production, set each variable in Railway.
# shared/env.ts validates the required set at boot and refuses to start if
# any are missing. Recommended vars print a warning but don't block boot.

# ─── Core (REQUIRED in production) ───────────────────────────────────────────

NODE_ENV=development
PORT=3001

# Postgres. Railway injects this automatically; local setups point at the
# docker-compose Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm?schema=public

# Redis for Bull queues, rate-limit buckets, KPI cache.
REDIS_URL=redis://localhost:6379

# JWT signing — MUST be at least 32 chars each in production. Dev auto-
# generates an ephemeral secret per process restart if these are unset.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AES-256-GCM key for encrypted provider credentials (Coliix API key etc.).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Public frontend origin — used for CORS + Socket.IO + OAuth redirect base.
FRONTEND_URL=http://localhost:5173

# Typed-confirmation code for POST /api/v1/admin/reset-crm. At least 6 chars.
# Rotate this if it leaks; the user just re-types the new value.
CRM_RESET_CODE=

# ─── WhatsApp / Evolution (REQUIRED in production if using WhatsApp) ─────────

# Evolution API — hosts WhatsApp sessions. Without these the /whatsapp
# endpoints return 503 WHATSAPP_NOT_CONFIGURED.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_URL=

# Shared secret Evolution must send as the `x-webhook-secret` header on
# every webhook. Configure it in Evolution's webhook settings. At least 16
# chars. Without this, anyone who guesses the webhook URL can forge events.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
EVOLUTION_WEBHOOK_SECRET=

# Picks the WhatsApp adapter. Only 'evolution' is wired today.
WHATSAPP_PROVIDER=evolution

# ─── Cloudflare R2 (REQUIRED in production — boot fails if unset) ────────────
# Used for product images, WhatsApp media, avatar uploads. Dev falls back to
# ./uploads on disk; Railway's filesystem is ephemeral so prod must use R2.

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ─── Youcan integration (optional) ───────────────────────────────────────────
# Only needed if customers connect their Youcan store. Safe to leave unset
# until the first OAuth flow.

YOUCAN_CLIENT_ID=
YOUCAN_CLIENT_SECRET=
YOUCAN_REDIRECT_URI=

# ─── Misc (optional) ─────────────────────────────────────────────────────────

# Used by server-initiated callbacks (payment, order sync). Defaults to
# http://localhost:$PORT — set to the public base URL in production.
BACKEND_URL=
