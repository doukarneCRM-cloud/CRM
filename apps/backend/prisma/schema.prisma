generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (canonical — match spec exactly) ───────────────────────────────────

// Confirmation pipeline — set by call-center agents on Order.confirmationStatus.
// Each value has dedicated handling (timestamps, side-effects); see
// orders.service.ts:updateOrderStatus for the canonical transition logic.
enum ConfirmationStatus {
  pending // default — not actioned yet
  confirmed // agent locked the sale; stock reserved, confirmedAt stamped
  cancelled // agent dropped it (requires cancellationReason); stock restored
  unreachable // client did not pick up; unreachableCount++; auto → cancelled at 9
  callback // client asked to be called later (callbackAt required); blinks today
  fake // fake / spam order
  out_of_stock // a variant ran out; cascades to all pending orders sharing the variant
  reported // client wants product on a future date (reportedAt required); blinks today
}

// Shipping pipeline — driven by the carrier (Coliix, etc.) once labelSent=true.
// Mappings from raw carrier wordings live in a separate carrier-mappings layer;
// this enum is the canonical bucket the rest of the CRM (KPIs, filters,
// commissions) reads from.
enum ShippingStatus {
  not_shipped // confirmed but no carrier label yet
  pushed // sent to carrier, label ready, awaiting first pickup scan
  picked_up // carrier collected the parcel
  in_transit // moving between hubs
  out_for_delivery // courier on the way to client
  failed_delivery // delivery attempt failed (no answer / voicemail / refused at door); may retry
  reported // client asked the courier to come back another day
  delivered // terminal — deliveredAt stamped, commission triggered
  returned // carrier sent the parcel back; admin verifies outcome (good/damaged)
}

// Returned-parcel verification outcome. Set by the warehouse when a returned
// parcel is physically inspected. Drives whether stock is restocked.
enum ReturnOutcome {
  good // restock the variants
  damaged // do not restock; counted as loss
}

enum OrderSource {
  youcan
  whatsapp
  instagram
  manual
}

enum DiscountType {
  fixed
  percentage
}

enum OrderLogType {
  confirmation
  shipping
  system
}

enum CustomerTag {
  normal
  vip
  blacklisted
}

// ─── Carrier integration enums ───────────────────────────────────────────────

// Lifecycle of a single parcel. The carrier (Coliix) drives transitions
// after the agent links the tracking code; only `pending` is a CRM-only
// holding state for the brief window before linking. ShippingStatus on
// Order is mirrored from this enum via mapColiixState.
enum ShipmentState {
  pending // CRM-only; agent hasn't entered tracking yet
  pushed // tracking linked, awaiting first carrier scan
  picked_up
  in_transit
  out_for_delivery
  failed_delivery
  reported // courier asked to come back another day
  delivered // terminal
  returned // terminal; verification handled at Order level
}

enum ShipmentEventSource {
  webhook // primary path — carrier calls our URL
  poll // fallback — our 60s tick polls the track API
  manual // admin manually patched (escape hatch)
}

// Every failure path writes a row so the Errors tab can surface what
// went wrong — no silent failures.
enum ColiixErrorType {
  webhook_invalid_secret
  webhook_invalid_payload
  webhook_unknown_tracking
  mapping_unknown_wording
  city_unknown
  api_credential_invalid
  api_timeout
  api_unknown
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  label String

  roles RolePermission[]
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  label String

  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  avatarUrl     String?
  roleId        String
  isActive      Boolean   @default(true)
  isOnline      Boolean   @default(false)
  lastHeartbeat DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role                Role                  @relation(fields: [roleId], references: [id])
  assignedOrders      Order[]               @relation("AgentOrders")
  orderLogs           OrderLog[]
  commissionRules     CommissionRule[]
  weeklyAttendance    WeeklyAttendance[]    @relation("AttendanceRecorder")
  salaryPayments      SalaryPayment[]       @relation("SalaryPayer")
  refreshTokens       RefreshToken[]
  atelieEmployee      AtelieEmployee?       @relation("AtelieUser")
  ownedTasks          AtelieTask[]          @relation("TaskOwner")
  taskComments        AtelieTaskComment[]   @relation("TaskCommenter")
  expenses            Expense[]             @relation("ExpenseAuthor")
  commissionPayments  CommissionPayment[]   @relation("CommissionAgent")
  recordedCommissions CommissionPayment[]   @relation("CommissionRecorder")
  verifiedReturns     Order[]               @relation("ReturnVerifier")
  notifications       Notification[]
  assignedProducts    Product[]             @relation("ProductAssignedAgent")
  whatsappSession     WhatsAppSession?
  messageLogs         MessageLog[]          @relation("MessageLogAgent")
  updatedTemplates    MessageTemplate[]     @relation("TemplateUpdater")
  createdRules        AutomationRule[]      @relation("RuleAuthor")
  assignedThreads     WhatsAppThread[]      @relation("ThreadAssignee")
  whatsappMessages    WhatsAppMessage[]     @relation("MessageAuthor")
  broadcastsAuthored  Broadcast[]           @relation("BroadcastAuthor")
  broadcastsReceived  BroadcastRecipient[]  @relation("BroadcastTarget")
  approvedSamples     ProductTest[]         @relation("SampleApprover")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Counters (atomic sequence for order references, etc.) ─────────────────

model Counter {
  key   String @id
  value Int    @default(0)
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id               String      @id @default(cuid())
  fullName         String
  phone            String      @unique // normalized +212XXXXXXXXX
  phoneDisplay     String // 06XXXXXXXX
  city             String
  address          String?
  tag              CustomerTag @default(normal)
  notes            String?
  // Flipped when the customer replies STOP / توقف on WhatsApp. Dispatcher
  // blocks all outbound messages to opted-out customers.
  whatsappOptOut   Boolean     @default(false)
  whatsappOptOutAt DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  orders  Order[]
  threads WhatsAppThread[]

  @@index([phone])
  @@index([city])
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id              String    @id @default(cuid())
  name            String
  sku             String    @unique
  description     String?
  imageUrl        String?
  basePrice       Decimal   @db.Decimal(12, 2)
  isActive        Boolean   @default(true)
  isPlaceholder   Boolean   @default(false) // true when auto-created during order import; replaced on real product import
  deletedAt       DateTime? // set when user hard-deletes from catalog; row is kept so historical orders still render (shown in red as "untracked")
  storeId         String?
  youcanId        String?
  assignedAgentId String? // optional default agent for "By Product" auto-assign strategy
  // Free-form clothing-measurements chart agents share with clients.
  // Shape: { columns: string[], rows: string[][] } where rows[i].length === columns.length.
  measurements    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store          Store?           @relation(fields: [storeId], references: [id])
  assignedAgent  User?            @relation("ProductAssignedAgent", fields: [assignedAgentId], references: [id])
  variants       ProductVariant[]
  productTests   ProductTest[]
  productionRuns ProductionRun[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  color     String?
  size      String?
  sku       String  @unique
  stock     Int     @default(0)
  price     Decimal @db.Decimal(12, 2)
  costPrice Decimal @default(0) @db.Decimal(12, 2) // COGS per unit — used for profit-by-product analytics
  youcanId  String? @unique

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  productionRunSizes ProductionRunSize[]

  @@index([productId])
}

// ─── Stores (YouCan integration) ─────────────────────────────────────────────

model Store {
  id              String    @id @default(cuid())
  name            String
  slug            String? // YouCan store slug
  // OAuth tokens (credentials are global env vars, tokens are per-store)
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  // Webhook
  webhookSecret   String?
  webhookId       String? // resthook subscription id
  // Field mapping: JSON object mapping YouCan checkout fields → CRM fields
  fieldMapping    Json?
  // State
  isActive        Boolean   @default(true)
  isConnected     Boolean   @default(false)
  // When false, the background poller skips this store and the order.create
  // webhook stops auto-importing — admin still has the manual "Import
  // orders" button. Defaults to false so freshly-linked stores don't pull
  // in any data until the admin explicitly opts in.
  autoSyncEnabled Boolean   @default(false)
  lastSyncAt      DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products   Product[]
  orders     Order[]
  importLogs ImportLog[]
}

enum ImportLogLevel {
  info
  warning
  error
}

model ImportLog {
  id        String         @id @default(cuid())
  storeId   String
  type      String // products_import, orders_import, webhook_order, sync, connection
  level     ImportLogLevel @default(info)
  message   String
  imported  Int            @default(0)
  skipped   Int            @default(0)
  errors    Int            @default(0)
  meta      Json? // error details, order refs, etc.
  createdAt DateTime       @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([storeId, createdAt])
  @@index([level])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                  String             @id @default(cuid())
  reference           String             @unique // ORD-YY-XXXXX
  source              OrderSource        @default(manual)
  customerId          String
  agentId             String?
  assignedAt          DateTime?
  confirmationStatus  ConfirmationStatus @default(pending)
  shippingStatus      ShippingStatus     @default(not_shipped)
  subtotal            Decimal            @default(0) @db.Decimal(12, 2)
  discountType        DiscountType?
  discountAmount      Decimal?           @db.Decimal(12, 2)
  total               Decimal            @db.Decimal(12, 2)
  shippingPrice       Decimal            @default(0) @db.Decimal(12, 2)
  confirmationNote    String?
  shippingInstruction String?
  cancellationReason  String?
  // ── Per-status timestamps ──────────────────────────────────────────────
  // Each card answers "X today / this week" by the date the transition
  // actually happened — not by createdAt. KPI cards filter on these
  // columns via filterBuilder.buildOrderWhereClause(filters, { dateField }).
  callbackAt          DateTime?
  reportedAt          DateTime?
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  unreachableAt       DateTime?
  deliveredAt         DateTime?
  labelSentAt         DateTime?

  // ── Counters & flags ───────────────────────────────────────────────────
  unreachableCount Int     @default(0) // auto-cancels at 9
  labelSent        Boolean @default(false)

  // ── External / source tracking ─────────────────────────────────────────
  youcanOrderId String? @unique
  storeId       String?

  // ── Lifecycle ──────────────────────────────────────────────────────────
  isArchived   Boolean @default(false)
  // Set together with isArchived=true by mergeOrders. Kept as a FK so
  // "how many orders get merged" is a one-query stat.
  mergedIntoId String?

  // ── Commission ─────────────────────────────────────────────────────────
  commissionAmount Decimal?  @db.Decimal(12, 2)
  commissionPaid   Boolean   @default(false)
  commissionPaidAt DateTime?

  // ── Returns verification (set when shippingStatus = returned) ──────────
  returnNote         String?
  returnOutcome      ReturnOutcome?
  returnVerifiedAt   DateTime?
  returnVerifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer         Customer     @relation(fields: [customerId], references: [id])
  agent            User?        @relation("AgentOrders", fields: [agentId], references: [id])
  store            Store?       @relation(fields: [storeId], references: [id])
  returnVerifiedBy User?        @relation("ReturnVerifier", fields: [returnVerifiedById], references: [id])
  mergedInto       Order?       @relation("OrderMerges", fields: [mergedIntoId], references: [id])
  mergedFrom       Order[]      @relation("OrderMerges")
  items            OrderItem[]
  logs             OrderLog[]
  messageLogs      MessageLog[]
  // Shipment is 1:1 with Order. The relation field is required on the
  // back-relation side here; the actual FK lives on Shipment.orderId.
  shipment         Shipment?

  @@index([confirmationStatus])
  @@index([shippingStatus])
  @@index([agentId])
  @@index([customerId])
  @@index([createdAt])
  @@index([isArchived])
  @@index([mergedIntoId])
  @@index([confirmationStatus, createdAt])
  @@index([shippingStatus, createdAt])
  @@index([agentId, confirmationStatus])
  @@index([agentId, commissionPaid])
  @@index([agentId, deliveredAt])
  // Fast lookup of today's callbacks/reports for the call-center blink list.
  @@index([callbackAt])
  @@index([reportedAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model OrderLog {
  id          String       @id @default(cuid())
  orderId     String
  type        OrderLogType @default(system)
  action      String
  performedBy String // display name or "System"
  userId      String?
  meta        Json?
  createdAt   DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([orderId, type])
}

// ─── Assignment & Shipping ────────────────────────────────────────────────────

model AssignmentRule {
  id        String   @id @default(cuid())
  name      String
  priority  Int      @default(0)
  cityMatch String?
  agentId   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ShippingCity {
  id       String  @id @default(cuid())
  name     String  @unique
  price    Decimal @db.Decimal(12, 2)
  zone     String?
  isActive Boolean @default(true)
}

// ─── Atelie ──────────────────────────────────────────────────────────────────

model AtelieEmployee {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  role        String
  baseSalary  Decimal  @default(0) @db.Decimal(12, 2) // weekly salary in MAD
  workingDays Int      @default(6) // divisor for daily rate
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())
  userId      String?  @unique

  user                 User?                 @relation("AtelieUser", fields: [userId], references: [id])
  attendance           WeeklyAttendance[]
  payments             SalaryPayment[]
  productionRunWorkers ProductionRunWorker[]
}

model WeeklyAttendance {
  id           String   @id @default(cuid())
  employeeId   String
  weekStart    DateTime // Monday 00:00 UTC of the week
  daysMask     Int      @default(0) // full-day mask — bit 0=Mon … bit 6=Sun
  halfDaysMask Int      @default(0) // half-day mask — same bit layout; mutually exclusive with daysMask
  daysWorked   Float    @default(0) // full + half * 0.5 (denormalized for fast salary calc)
  notes        String?
  recordedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   AtelieEmployee @relation(fields: [employeeId], references: [id])
  recordedBy User?          @relation("AttendanceRecorder", fields: [recordedById], references: [id])

  @@unique([employeeId, weekStart])
  @@index([weekStart])
}

model SalaryPayment {
  id         String    @id @default(cuid())
  employeeId String
  weekStart  DateTime // matches WeeklyAttendance.weekStart
  amount     Decimal   @db.Decimal(12, 2) // daysWorked × (baseSalary / workingDays)
  paidAmount Decimal   @default(0) @db.Decimal(12, 2)
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  paidById   String?
  notes      String?
  // Pay-envelope extras: commission added on top of the computed amount,
  // optional supplement hours worked beyond the regular schedule. Both are
  // edited via the (+) button on the salary row and printed onto the
  // 100×100mm label that gets stuck to the envelope.
  commission       Decimal @default(0) @db.Decimal(12, 2)
  supplementHours  Float   @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee AtelieEmployee @relation(fields: [employeeId], references: [id])
  paidBy   User?          @relation("SalaryPayer", fields: [paidById], references: [id])

  @@unique([employeeId, weekStart])
  @@index([employeeId])
}

// ─── Atelie — Raw materials ───────────────────────────────────────────────────

enum MaterialCategory {
  fabric
  accessory
  needle
  thread
  other
}

enum MaterialUnit {
  meter
  piece
  kilogram
  spool
  box
}

model AtelieMaterial {
  id                String           @id @default(cuid())
  name              String
  category          MaterialCategory
  unit              MaterialUnit
  stock             Float            @default(0)
  lowStockThreshold Float            @default(0)
  unitCost          Decimal?         @db.Decimal(12, 2)
  supplier          String?
  notes             String?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  movements              MaterialMovement[]
  productTestAccessories ProductTestAccessory[]
  productionConsumptions ProductionConsumption[]

  @@index([category])
}

enum MaterialMovementType {
  in
  out
  adjustment
}

model MaterialMovement {
  id         String               @id @default(cuid())
  materialId String
  type       MaterialMovementType
  quantity   Float // always positive; `type` dictates sign applied to stock
  reason     String?
  userId     String?
  createdAt  DateTime             @default(now())

  material              AtelieMaterial         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  productionConsumption ProductionConsumption?

  @@index([materialId, createdAt])
}

// ─── Atelie — Fabric rolls & production runs ─────────────────────────────────

enum ProductionRunStatus {
  draft
  active
  finished
  cancelled
}

enum ConsumptionSourceType {
  fabric_roll
  accessory
}

enum ProductionStage {
  cut
  sew
  finish
  qc
  packed
}

enum ProductionLogType {
  system
  stage
  consumption
  labor
  note
  status
}

enum LaborAllocationMode {
  by_pieces
  by_complexity
  manual
}

model FabricType {
  id        String   @id @default(cuid())
  name      String   @unique
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rolls       FabricRoll[]
  testFabrics ProductTestFabric[]
  runFabrics  ProductionRunFabric[]
}

model FabricRoll {
  id               String   @id @default(cuid())
  fabricTypeId     String
  color            String
  widthCm          Float?
  initialLength    Float
  remainingLength  Float
  unitCostPerMeter Decimal  @db.Decimal(12, 2)
  purchaseDate     DateTime
  supplier         String?
  reference        String?
  notes            String?
  isDepleted       Boolean  @default(false)
  expenseId        String?  @unique
  createdAt        DateTime @default(now())

  fabricType   FabricType              @relation(fields: [fabricTypeId], references: [id])
  expense      Expense?                @relation(fields: [expenseId], references: [id])
  consumptions ProductionConsumption[]

  @@index([fabricTypeId, color])
  @@index([isDepleted])
}

enum SampleStatus {
  draft
  tested
  approved
  archived
}

model ProductTest {
  id           String       @id @default(cuid())
  name         String
  productId    String?
  videoUrl     String?
  // Long-form description shown to admins/buyers — separate from internal
  // `notes` (which can stay private). HTML stripped on save in the service.
  description  String?
  // Sample lifecycle. `approved` is the gate that unlocks creating a
  // ProductionRun from this sample.
  status       SampleStatus @default(draft)
  approvedAt   DateTime?
  approvedById String?

  // Cost-calc inputs. Fees are per-piece overrides on the sample (a
  // YouCan / fulfillment fee can vary per garment). Markup feeds
  // `suggestedPrice`. The service recomputes `estimatedCostPerPiece` and
  // `suggestedPrice` on every save so they're always current.
  laborMadPerPiece Decimal? @db.Decimal(12, 2)
  confirmationFee  Decimal? @db.Decimal(12, 2)
  deliveryFee      Decimal? @db.Decimal(12, 2)
  markupPercent    Decimal? @db.Decimal(5, 2)
  suggestedPrice   Decimal? @db.Decimal(12, 2)

  estimatedCostPerPiece Decimal? @db.Decimal(12, 2)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  product     Product?               @relation(fields: [productId], references: [id])
  approvedBy  User?                  @relation("SampleApprover", fields: [approvedById], references: [id])
  fabrics     ProductTestFabric[]
  sizes       ProductTestSize[]
  accessories ProductTestAccessory[]
  photos      ProductTestPhoto[]
  runs        ProductionRun[]

  @@index([status, createdAt])
}

model ProductTestPhoto {
  id        String   @id @default(cuid())
  testId    String
  url       String
  caption   String?
  // Fractional position so reorders never need a backfill update of the
  // entire list — same trick used by AtelieTask.position.
  position  Float    @default(0)
  createdAt DateTime @default(now())

  test ProductTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, position])
}

model ProductTestFabric {
  id           String @id @default(cuid())
  testId       String
  fabricTypeId String
  role         String

  test       ProductTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  fabricType FabricType  @relation(fields: [fabricTypeId], references: [id])

  @@unique([testId, fabricTypeId, role])
}

model ProductTestSize {
  id            String @id @default(cuid())
  testId        String
  size          String
  tracingMeters Float

  test ProductTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, size])
}

model ProductTestAccessory {
  id               String   @id @default(cuid())
  testId           String
  materialId       String
  quantityPerPiece Float
  // Snapshot the material's unit cost at the moment the accessory was
  // added to the sample, so later AtelieMaterial price changes don't
  // retroactively rewrite the sample's estimated cost. Falls back to
  // material.unitCost in the calculator when null (legacy rows).
  unitCostSnapshot Decimal? @db.Decimal(12, 2)

  test     ProductTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  material AtelieMaterial @relation(fields: [materialId], references: [id])

  @@unique([testId, materialId])
}

model ProductionRun {
  id               String              @id @default(cuid())
  reference        String              @unique
  testId           String?
  productId        String?
  status           ProductionRunStatus @default(draft)
  startDate        DateTime
  endDate          DateTime?
  expectedPieces   Int                 @default(0)
  actualPieces     Int                 @default(0)
  materialsCost    Decimal             @default(0) @db.Decimal(12, 2)
  laborCost        Decimal             @default(0) @db.Decimal(12, 2)
  totalCost        Decimal             @default(0) @db.Decimal(12, 2)
  costPerPiece     Decimal             @default(0) @db.Decimal(12, 2)
  notes            String?
  // Cost-split context. When the run touches a week with peer runs, the
  // workshop's labor cost is divided between them per `laborAllocation`.
  // `manual` requires `laborManualShare` (0..100). Computed snapshot
  // stored on the run when the week closes.
  weekId           String?
  laborAllocation  LaborAllocationMode @default(by_pieces)
  laborManualShare Decimal?            @db.Decimal(5, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  test         ProductTest?            @relation(fields: [testId], references: [id])
  product      Product?                @relation(fields: [productId], references: [id])
  week         ProductionWeek?         @relation(fields: [weekId], references: [id])
  stages       ProductionRunStage[]
  logs         ProductionLog[]
  fabrics      ProductionRunFabric[]
  sizes        ProductionRunSize[]
  consumptions ProductionConsumption[]
  workers      ProductionRunWorker[]

  @@index([status, startDate])
}

model ProductionRunFabric {
  id           String @id @default(cuid())
  runId        String
  fabricTypeId String
  role         String

  run        ProductionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fabricType FabricType    @relation(fields: [fabricTypeId], references: [id])

  @@unique([runId, fabricTypeId, role])
}

model ProductionRunSize {
  id             String  @id @default(cuid())
  runId          String
  size           String
  tracingMeters  Float
  expectedPieces Int
  actualPieces   Int     @default(0)
  variantId      String?

  run     ProductionRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([runId, size])
}

model ProductionConsumption {
  id           String                @id @default(cuid())
  runId        String
  sourceType   ConsumptionSourceType
  fabricRollId String?
  materialId   String?
  movementId   String?               @unique
  quantity     Float
  unitCost     Decimal               @db.Decimal(12, 2)
  createdAt    DateTime              @default(now())
  createdById  String?

  run        ProductionRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  fabricRoll FabricRoll?       @relation(fields: [fabricRollId], references: [id])
  material   AtelieMaterial?   @relation(fields: [materialId], references: [id])
  movement   MaterialMovement? @relation(fields: [movementId], references: [id])

  @@index([runId])
}

model ProductionRunWorker {
  id         String  @id @default(cuid())
  runId      String
  employeeId String
  role       String?

  run      ProductionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  employee AtelieEmployee @relation(fields: [employeeId], references: [id])

  @@unique([runId, employeeId])
}

// Per-stage progress on a run. Stages are fixed: cut → sew → finish → qc
// → packed (matches the typical workshop flow). One row per (run, stage)
// is created lazily as the run advances. `output - rejected` carried into
// the next stage's `input` lets the timeline show wastage at each step.
model ProductionRunStage {
  id             String          @id @default(cuid())
  runId          String
  stage          ProductionStage
  startedAt      DateTime?
  completedAt    DateTime?
  inputPieces    Int             @default(0)
  outputPieces   Int             @default(0)
  rejectedPieces Int             @default(0)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  run ProductionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stage])
  @@index([runId, stage])
}

// Audit trail for every meaningful action on a run. Mirrors OrderLog —
// stage transitions, consumption events, labor splits, and free-form
// notes all land here so supervisors can reconstruct the run after the
// fact without diffing snapshots.
model ProductionLog {
  id            String            @id @default(cuid())
  runId         String
  type          ProductionLogType
  action        String
  performedBy   String?
  performedById String?
  meta          Json?
  createdAt     DateTime          @default(now())

  run ProductionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}

// Calendar week that groups runs sharing workshop attendance. Created
// lazily when a run's startDate falls in a new week (Monday 00:00 UTC).
// `laborTotal` is recomputed from WeeklyAttendance × employee daily rate
// at close-time; `closed` locks the split so payroll doesn't drift.
model ProductionWeek {
  id         String    @id @default(cuid())
  weekStart  DateTime  @unique
  laborTotal Decimal   @default(0) @db.Decimal(12, 2)
  closed     Boolean   @default(false)
  closedAt   DateTime?
  closedById String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  runs ProductionRun[]
}

// ─── Atelie — Team Tasks ──────────────────────────────────────────────────────

enum AtelieTaskStatus {
  backlog
  processing
  done
  forgotten
  incomplete
}

enum AtelieTaskVisibility {
  private
  shared
}

model AtelieTask {
  id               String               @id @default(cuid())
  ownerId          String
  title            String
  description      String?
  status           AtelieTaskStatus     @default(backlog)
  visibility       AtelieTaskVisibility @default(private)
  color            String?
  position         Float // fractional indexing within column
  incompleteReason String?
  dueAt            DateTime?
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  owner       User                   @relation("TaskOwner", fields: [ownerId], references: [id])
  comments    AtelieTaskComment[]
  attachments AtelieTaskAttachment[]
  hides       AtelieTaskHide[]

  @@index([ownerId, status, position])
  @@index([visibility, status, position])
}

model AtelieTaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  task   AtelieTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User       @relation("TaskCommenter", fields: [authorId], references: [id])

  @@index([taskId, createdAt])
}

model AtelieTaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  uploadedBy String
  fileUrl    String
  fileName   String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  task AtelieTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model AtelieTaskHide {
  userId    String
  taskId    String
  createdAt DateTime @default(now())

  task AtelieTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([userId, taskId])
  @@index([taskId])
}

// ─── Settings & Config ────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Analytics — Expenses ────────────────────────────────────────────────────
// Free-form running log of money spent (ads, rent, packaging, salaries paid
// outside atelie, anything). Shown in the Analytics → Expenses tab and
// aggregated into the Profit tab.
model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime // user-selected date of the expense (not createdAt)
  fileUrl     String? // optional invoice / screenshot upload
  // Where this row originated. "manual" = typed by an admin in the
  // Expenses tab; "facebook" / "tiktok" / "google" = auto-imported from
  // an ad-platform integration (one row per account per day). Lets the
  // Expenses tab filter / colour-code automated rows differently and
  // prevents the integration sync from clobbering manual entries.
  source      String   @default("manual")
  addedById   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addedBy    User?       @relation("ExpenseAuthor", fields: [addedById], references: [id])
  fabricRoll FabricRoll?
  adSpendDay AdSpendDay?

  @@index([date])
  @@index([source])
}

// ─── Money — Commission payments ─────────────────────────────────────────────
// Ledger of disbursements to agents. `amount` is what was actually paid out
// (which may cover many orders); `orderIds` stores which orders the payment
// cleared so we can mark `Order.commissionPaid = true` atomically.
model CommissionPayment {
  id           String    @id @default(cuid())
  agentId      String
  amount       Decimal   @db.Decimal(12, 2)
  periodFrom   DateTime?
  periodTo     DateTime?
  paidAt       DateTime  @default(now())
  notes        String?
  fileUrl      String?
  orderIds     String[] // order IDs cleared by this payment
  recordedById String?
  createdAt    DateTime  @default(now())

  agent      User  @relation("CommissionAgent", fields: [agentId], references: [id])
  recordedBy User? @relation("CommissionRecorder", fields: [recordedById], references: [id])

  @@index([agentId])
  @@index([paidAt])
}

model CommissionRule {
  id        String   @id @default(cuid())
  agentId   String
  type      String
  // Decimal works for both flat-MAD rules ("50.00") and percent rules
  // ("5.00" meaning 5%). The interpretation lives in `type`.
  value     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  agent User @relation(fields: [agentId], references: [id])
}

// ─── Notifications ───────────────────────────────────────────────────────────
// One row per recipient — admin-targeted events create one row per admin so
// each user has an independent read state. `href` is the optional client route
// the TopBar bell should navigate to when the notification is clicked.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  kind      String // e.g. "order_assigned" | "order_confirmed" | "system"
  title     String
  body      String?
  href      String?
  orderId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ─── WhatsApp automation ────────────────────────────────────────────────────
// Client & agent notifications sent automatically on order status transitions
// and commission payouts. Every `MessageTemplate` has a unique trigger; the
// dispatcher fans out to one `MessageLog` row per recipient, enqueued into the
// Bull `whatsappQueue` and pushed through Evolution API per-agent sessions.
enum AutomationTrigger {
  confirmation_confirmed
  confirmation_cancelled
  confirmation_unreachable
  confirmation_callback
  confirmation_reported
  shipping_pushed
  shipping_picked_up
  shipping_in_transit
  shipping_out_for_delivery
  shipping_failed_delivery
  shipping_reported
  shipping_delivered
  shipping_returned
  commission_paid
}

enum WhatsAppSessionStatus {
  disconnected
  connecting
  connected
  error
}

enum MessageLogStatus {
  queued
  sending
  sent
  delivered
  failed
  dead // gave up after Bull exhausted retries — shown in DLQ, requeue-able
}

enum WhatsAppThreadStatus {
  open
  closed
  snoozed
}

enum WhatsAppMessageDirection {
  in
  out
}

model MessageTemplate {
  id          String            @id @default(cuid())
  trigger     AutomationTrigger @unique
  enabled     Boolean           @default(false)
  body        String
  updatedById String?
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())

  updatedBy User?            @relation("TemplateUpdater", fields: [updatedById], references: [id])
  rules     AutomationRule[]
}

// A rule layers condition-based routing on top of a template. Multiple rules
// can fire for the same trigger with different conditions and priorities —
// the dispatcher loads enabled rules for a trigger ordered by priority desc
// and fires the first that matches (`overlap='first'`) or all matches
// (`overlap='all'`). Conditions are a whitelisted JSON shape evaluated by
// conditionEvaluator.ts (no arbitrary code).
model AutomationRule {
  id             String            @id @default(cuid())
  trigger        AutomationTrigger
  name           String
  priority       Int               @default(0)
  enabled        Boolean           @default(true)
  overlap        String            @default("first") // "first" | "all"
  conditions     Json              @default("{}")
  templateId     String
  sendFromSystem Boolean           @default(false)
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  template  MessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("RuleAuthor", fields: [createdById], references: [id])
  logs      MessageLog[]

  @@index([trigger, enabled, priority])
}

model WhatsAppSession {
  id            String                @id @default(cuid())
  userId        String?               @unique
  instanceName  String                @unique
  status        WhatsAppSessionStatus @default(disconnected)
  phoneNumber   String?
  lastHeartbeat DateTime?
  connectedAt   DateTime?
  createdAt     DateTime              @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model MessageLog {
  id             String            @id @default(cuid())
  trigger        AutomationTrigger
  ruleId         String?
  orderId        String?
  agentId        String?
  recipientPhone String
  body           String
  status         MessageLogStatus  @default(queued)
  providerId     String?
  error          String?
  dedupeKey      String            @unique
  attempts       Int               @default(0)
  createdAt      DateTime          @default(now())
  sentAt         DateTime?

  rule  AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  order Order?          @relation(fields: [orderId], references: [id])
  agent User?           @relation("MessageLogAgent", fields: [agentId], references: [id])

  messages WhatsAppMessage[]

  @@index([status, createdAt])
  @@index([orderId])
  @@index([trigger, createdAt])
}

// Two-way inbox. One thread per customer ↔ agent-session pairing. Inbound
// messages land here; automation-driven outbound messages are appended as
// direction='out' so the agent sees the full history inline with their
// manual replies.
model WhatsAppThread {
  id              String               @id @default(cuid())
  customerId      String?
  assignedAgentId String?
  customerPhone   String
  lastMessageAt   DateTime             @default(now())
  unreadCount     Int                  @default(0)
  status          WhatsAppThreadStatus @default(open)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  customer      Customer?         @relation(fields: [customerId], references: [id])
  assignedAgent User?             @relation("ThreadAssignee", fields: [assignedAgentId], references: [id])
  messages      WhatsAppMessage[]

  @@unique([customerPhone, assignedAgentId])
  @@index([assignedAgentId, status, lastMessageAt])
  @@index([customerId])
}

model WhatsAppMessage {
  id           String                   @id @default(cuid())
  threadId     String
  direction    WhatsAppMessageDirection
  body         String
  mediaUrl     String?
  mediaType    String? // 'image' | 'audio' | 'video' | 'sticker' | 'document'
  mediaMime    String?
  fromPhone    String
  toPhone      String
  providerId   String?
  messageLogId String?
  authorUserId String?
  readAt       DateTime?
  createdAt    DateTime                 @default(now())

  thread     WhatsAppThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messageLog MessageLog?    @relation(fields: [messageLogId], references: [id], onDelete: SetNull)
  author     User?          @relation("MessageAuthor", fields: [authorUserId], references: [id])

  @@index([threadId, createdAt])
  @@index([providerId])
}

// ─── Broadcasts (admin push notifications) ──────────────────────────────────

// Admin-pushed announcements aimed at one or more agents. Two kinds:
//  - POPUP: blocking modal that re-shows on every page load until the agent
//    clicks OK. The OK click counts as "read" and the popup never returns
//    for that agent.
//  - BAR: sticky banner at the top of the Call Center page. Agents cannot
//    dismiss; only the admin can flip `isActive` to false to retire it.
// Each broadcast can carry text + optional image + optional clickable link.
// Per-recipient rows track delivery / acknowledgement / link clicks so the
// admin can audit who actually saw the message.
enum BroadcastKind {
  POPUP
  BAR
}

model Broadcast {
  id            String        @id @default(cuid())
  kind          BroadcastKind
  title         String
  body          String?
  imageUrl      String?
  linkUrl       String?
  isActive      Boolean       @default(true)
  createdById   String
  createdBy     User          @relation("BroadcastAuthor", fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  deactivatedAt DateTime?

  recipients BroadcastRecipient[]

  @@index([kind, isActive, createdAt])
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("BroadcastTarget", fields: [userId], references: [id], onDelete: Cascade)
  deliveredAt DateTime?
  ackedAt     DateTime?
  clickedAt   DateTime?
  clickCount  Int       @default(0)

  @@unique([broadcastId, userId])
  @@index([userId, ackedAt])
}

// ─── Carrier integration (Coliix v1) ─────────────────────────────────────────
// Single carrier today (Coliix) but the schema is multi-carrier from day 1
// so a future provider can plug in without a migration. Per-hub accounts
// because Coliix issues one API key per hub (Agadir today; Casablanca,
// Marrakech, … if the user opens more).

model Carrier {
  id        String   @id @default(cuid())
  code      String   @unique // "coliix"
  label     String // "Coliix"
  createdAt DateTime @default(now())

  accounts CarrierAccount[]
}

// One row per (carrier × hub). The agent picks a hub when linking a
// tracking code if more than one is active. Single-hub setup auto-picks
// the only active row.
model CarrierAccount {
  id            String    @id @default(cuid())
  carrierId     String
  hubLabel      String // "Agadir", "Casablanca", custom
  apiBaseUrl    String // https://my.coliix.com
  apiKey        String // AES-256-GCM blob (encryptSecret)
  webhookSecret String // 28-hex-char path segment
  isActive      Boolean   @default(false)
  // Last time the test endpoint was hit + the outcome. Drives the
  // green/red dot on the Setup tab.
  lastHealthAt  DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  carrier   Carrier       @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  shipments Shipment[]
  cities    CarrierCity[]

  @@unique([carrierId, hubLabel])
  @@index([carrierId, isActive])
}

// "Cities + delivery fees" cached per account. Imported from CSV; admin
// can edit a fee inline. Used to validate the city BEFORE linking a
// tracking code (admin sees `city_unknown` error if the customer's city
// isn't in this table) and to compute carrier cost on the dashboard.
model CarrierCity {
  id            String   @id @default(cuid())
  accountId     String
  ville         String
  zone          String?
  deliveryPrice Decimal? @db.Decimal(12, 2)
  refreshedAt   DateTime @default(now())

  account CarrierAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, ville])
  @@index([accountId, ville])
}

// One per parcel. Created at the moment the agent links a Coliix
// tracking code to an order via the "Mark as Shipped" modal — we don't
// push to Coliix's create API (the user creates the parcel directly in
// Coliix's portal). idempotencyKey defaults to Order.reference so a
// double-click on the modal cannot create two shipments.
model Shipment {
  id             String        @id @default(cuid())
  orderId        String        @unique
  accountId      String
  trackingCode   String        @unique // Coliix tracking, e.g. 4-CSA04261254261OH
  idempotencyKey String        @unique // Order.reference, prevents double-link
  state          ShipmentState @default(pushed)
  rawState       String? // last raw wording observed from Coliix
  cod            Decimal       @db.Decimal(12, 2) // total customer pays carrier
  city           String
  address        String
  recipientName  String
  recipientPhone String
  goodsLabel     String // marchandise (built from order items)
  goodsQty       Int
  comment        String? // shipping instruction / driver note
  pushedAt       DateTime      @default(now())
  deliveredAt    DateTime?
  returnedAt     DateTime?
  // Adaptive polling — null = terminal, no more polls. Worker rewrites
  // this each ingest. Webhook is primary; polling is a 60s fallback.
  nextPollAt     DateTime?
  lastPolledAt   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  account CarrierAccount  @relation(fields: [accountId], references: [id])
  events  ShipmentEvent[]

  @@index([state, updatedAt])
  @@index([nextPollAt])
}

// Append-only log — every webhook hit, every poll diff, every manual
// patch. dedupeHash = sha256(code|state|datereported), second-layer
// replay guard after the Redis NX SET in the webhook handler.
model ShipmentEvent {
  id          String              @id @default(cuid())
  shipmentId  String
  source      ShipmentEventSource
  rawState    String?
  mappedState ShipmentState? // null when the wording is unknown — admin reviews
  driverNote  String?
  occurredAt  DateTime
  receivedAt  DateTime            @default(now())
  payload     Json
  dedupeHash  String

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, dedupeHash])
  @@index([shipmentId, occurredAt])
}

// Admin-editable mapping from Coliix's literal wording to our internal
// ShipmentState. internalState=null means "stay raw" — the wording is
// stored on the shipment for visibility but the enum bucket is left
// alone. Auto-discovered rows land here with internalState=null until
// admin reviews them; saving a value re-buckets every historical
// ShipmentEvent + Shipment that used that wording.
model ColiixStatusMapping {
  id            String         @id @default(cuid())
  rawWording    String         @unique
  internalState ShipmentState?
  isTerminal    Boolean        @default(false)
  note          String?
  updatedById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([internalState])
}

// Every failure path writes here. The Errors tab lists them with retry
// + resolve actions; admins also see a red dot on the Integrations menu
// when unresolved errors exist.
model ColiixIntegrationError {
  id           String          @id @default(cuid())
  type         ColiixErrorType
  shipmentId   String?
  orderId      String?
  accountId    String?
  message      String
  meta         Json?
  resolved     Boolean         @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime        @default(now())

  @@index([type, resolved, createdAt])
  @@index([shipmentId])
  @@index([orderId])
}

// ─── Ad platforms (Facebook today; TikTok / Google later) ───────────────────
//
// One row per connected ad account. Tokens are stored AES-256-GCM encrypted
// at rest (see shared/encryption). `provider` is future-proofed so a single
// schema covers TikTok / Google Ads when those land — same shape, different
// API client.
model AdAccount {
  id             String    @id @default(cuid())
  provider       String    @default("facebook") // facebook | tiktok | google
  externalId     String // Meta's `act_<id>`
  name           String
  // Optional Meta Business Manager id — needed to fetch business invoices
  // (those live at the business level, not the ad account level).
  businessId     String?
  accessToken    String? // long-lived token, encrypted
  tokenExpiresAt DateTime?
  isActive       Boolean   @default(true)
  isConnected    Boolean   @default(false)
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  spendDays AdSpendDay[]
  campaigns AdCampaign[]
  invoices  AdInvoice[]

  @@unique([provider, externalId])
  @@index([provider, isActive])
}

// One row per ad account per day. The integration sync upserts on
// (accountId, date) so re-running it for the same day updates spend in
// place rather than duplicating. `expenseId` links to the auto-created
// Expense row so deleting / disconnecting can cascade-clean the Money
// page if the operator wants.
model AdSpendDay {
  id        String   @id @default(cuid())
  accountId String
  date      DateTime @db.Date
  spend     Decimal  @db.Decimal(12, 2)
  currency  String
  expenseId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account AdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expense Expense?  @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@unique([accountId, date])
  @@index([date])
}

model AdCampaign {
  id          String  @id @default(cuid())
  accountId   String
  externalId  String
  name        String
  status      String // ACTIVE | PAUSED | ARCHIVED | DELETED
  spendCached Decimal @default(0) @db.Decimal(12, 2)
  // Last 7-day spend cached so the table renders without a per-row API call.
  // Refreshed every sync. Currency is whatever the parent ad account uses.
  refreshedAt DateTime @default(now())

  account AdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  adsets  AdAdset[]

  @@unique([accountId, externalId])
  @@index([accountId, status])
}

model AdAdset {
  id          String  @id @default(cuid())
  campaignId  String
  externalId  String
  name        String
  status      String
  spendCached Decimal @default(0) @db.Decimal(12, 2)
  refreshedAt DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, externalId])
  @@index([campaignId, status])
}

// Read-only mirror of Meta Business Manager invoices. We don't push, we
// just surface them in the Facebook tab so the operator doesn't have to
// log into Meta's billing portal to see what's been billed.
model AdInvoice {
  id          String   @id @default(cuid())
  accountId   String
  externalId  String // Meta billing line id
  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
  status      String // PAID | PENDING | OVERDUE
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account AdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, externalId])
  @@index([periodEnd])
}
