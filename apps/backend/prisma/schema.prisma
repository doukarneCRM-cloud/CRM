generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (canonical — match spec exactly) ───────────────────────────────────

enum ConfirmationStatus {
  pending
  awaiting
  confirmed
  cancelled
  unreachable
  callback
  fake
  out_of_stock
  reported
}

enum ShippingStatus {
  not_shipped
  label_created
  picked_up
  in_transit
  out_for_delivery
  delivered
  attempted
  returned
  return_validated
  return_refused
  exchange
  lost
  destroyed
}

enum OrderSource {
  youcan
  whatsapp
  instagram
  manual
}

enum DiscountType {
  fixed
  percentage
}

enum OrderLogType {
  confirmation
  shipping
  system
}

enum CustomerTag {
  normal
  vip
  blacklisted
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  label String

  roles RolePermission[]
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  label String

  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  avatarUrl     String?
  roleId        String
  isActive      Boolean   @default(true)
  isOnline      Boolean   @default(false)
  lastHeartbeat DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role                Role                @relation(fields: [roleId], references: [id])
  assignedOrders      Order[]             @relation("AgentOrders")
  orderLogs           OrderLog[]
  commissionRules     CommissionRule[]
  weeklyAttendance    WeeklyAttendance[]  @relation("AttendanceRecorder")
  salaryPayments      SalaryPayment[]     @relation("SalaryPayer")
  refreshTokens       RefreshToken[]
  atelieEmployee      AtelieEmployee?     @relation("AtelieUser")
  ownedTasks          AtelieTask[]        @relation("TaskOwner")
  taskComments        AtelieTaskComment[] @relation("TaskCommenter")
  expenses            Expense[]           @relation("ExpenseAuthor")
  commissionPayments  CommissionPayment[] @relation("CommissionAgent")
  recordedCommissions CommissionPayment[] @relation("CommissionRecorder")
  verifiedReturns     Order[]             @relation("ReturnVerifier")
  notifications       Notification[]
  assignedProducts    Product[]           @relation("ProductAssignedAgent")
  whatsappSession     WhatsAppSession?
  messageLogs         MessageLog[]        @relation("MessageLogAgent")
  updatedTemplates    MessageTemplate[]   @relation("TemplateUpdater")
  createdRules        AutomationRule[]    @relation("RuleAuthor")
  assignedThreads     WhatsAppThread[]    @relation("ThreadAssignee")
  whatsappMessages    WhatsAppMessage[]   @relation("MessageAuthor")
  createdStatusGroups ShippingStatusGroup[] @relation("StatusGroupAuthor")
  broadcastsAuthored  Broadcast[]           @relation("BroadcastAuthor")
  broadcastsReceived  BroadcastRecipient[]  @relation("BroadcastTarget")
  approvedSamples     ProductTest[]         @relation("SampleApprover")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Counters (atomic sequence for order references, etc.) ─────────────────

model Counter {
  key   String @id
  value Int    @default(0)
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id              String      @id @default(cuid())
  fullName        String
  phone           String      @unique // normalized +212XXXXXXXXX
  phoneDisplay    String // 06XXXXXXXX
  city            String
  address         String?
  tag             CustomerTag @default(normal)
  notes           String?
  // Flipped when the customer replies STOP / توقف on WhatsApp. Dispatcher
  // blocks all outbound messages to opted-out customers.
  whatsappOptOut  Boolean     @default(false)
  whatsappOptOutAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orders  Order[]
  threads WhatsAppThread[]

  @@index([phone])
  @@index([city])
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id              String    @id @default(cuid())
  name            String
  sku             String    @unique
  description     String?
  imageUrl        String?
  basePrice       Decimal   @db.Decimal(12, 2)
  isActive        Boolean   @default(true)
  isPlaceholder   Boolean   @default(false) // true when auto-created during order import; replaced on real product import
  deletedAt       DateTime? // set when user hard-deletes from catalog; row is kept so historical orders still render (shown in red as "untracked")
  storeId         String?
  youcanId        String?
  assignedAgentId String? // optional default agent for "By Product" auto-assign strategy
  // Free-form clothing-measurements chart agents share with clients.
  // Shape: { columns: string[], rows: string[][] } where rows[i].length === columns.length.
  measurements    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store          Store?           @relation(fields: [storeId], references: [id])
  assignedAgent  User?            @relation("ProductAssignedAgent", fields: [assignedAgentId], references: [id])
  variants       ProductVariant[]
  productTests   ProductTest[]
  productionRuns ProductionRun[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  color     String?
  size      String?
  sku       String  @unique
  stock     Int     @default(0)
  price     Decimal @db.Decimal(12, 2)
  costPrice Decimal @default(0) @db.Decimal(12, 2) // COGS per unit — used for profit-by-product analytics
  youcanId  String? @unique

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  productionRunSizes ProductionRunSize[]

  @@index([productId])
}

// ─── Stores (YouCan integration) ─────────────────────────────────────────────

model Store {
  id             String    @id @default(cuid())
  name           String
  slug           String? // YouCan store slug
  // OAuth tokens (credentials are global env vars, tokens are per-store)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  // Webhook
  webhookSecret  String?
  webhookId      String? // resthook subscription id
  // Field mapping: JSON object mapping YouCan checkout fields → CRM fields
  fieldMapping   Json?
  // State
  isActive       Boolean   @default(true)
  isConnected    Boolean   @default(false)
  // When false, the background poller skips this store and the order.create
  // webhook stops auto-importing — admin still has the manual "Import
  // orders" button. Defaults to false so freshly-linked stores don't pull
  // in any data until the admin explicitly opts in.
  autoSyncEnabled Boolean  @default(false)
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  products   Product[]
  orders     Order[]
  importLogs ImportLog[]
}

// ─── Shipping providers (Coliix, etc.) ───────────────────────────────────────
// One row per integration. Seeded lazily on first access — see
// integrations/providers.service.getOrCreate. API key is stored encrypted;
// read via decryptSecret before handing to HTTP clients.
model ShippingProvider {
  id            String    @id @default(cuid())
  name          String    @unique // "coliix"
  apiBaseUrl    String
  apiKey        String? // encrypted (AES-256-GCM blob)
  webhookSecret String // random path-segment secret
  isActive      Boolean   @default(false)
  lastCheckedAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum ImportLogLevel {
  info
  warning
  error
}

model ImportLog {
  id        String         @id @default(cuid())
  storeId   String
  type      String // products_import, orders_import, webhook_order, sync, connection
  level     ImportLogLevel @default(info)
  message   String
  imported  Int            @default(0)
  skipped   Int            @default(0)
  errors    Int            @default(0)
  meta      Json? // error details, order refs, etc.
  createdAt DateTime       @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([storeId, createdAt])
  @@index([level])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                  String             @id @default(cuid())
  reference           String             @unique // ORD-YY-XXXXX
  source              OrderSource        @default(manual)
  customerId          String
  agentId             String?
  assignedAt          DateTime?
  confirmationStatus  ConfirmationStatus @default(pending)
  shippingStatus      ShippingStatus     @default(not_shipped)
  subtotal            Decimal            @default(0) @db.Decimal(12, 2)
  discountType        DiscountType?
  discountAmount      Decimal?           @db.Decimal(12, 2)
  total               Decimal            @db.Decimal(12, 2)
  shippingPrice       Decimal            @default(0) @db.Decimal(12, 2)
  confirmationNote    String?
  shippingInstruction String?
  cancellationReason  String?
  callbackAt          DateTime?
  coliixTrackingId    String?
  youcanOrderId       String?            @unique
  labelSent           Boolean            @default(false)
  labelSentAt         DateTime?
  storeId             String?
  isArchived          Boolean            @default(false)
  commissionAmount    Decimal?           @db.Decimal(12, 2)
  commissionPaid      Boolean            @default(false)
  commissionPaidAt    DateTime?
  deliveredAt         DateTime?
  unreachableCount    Int                @default(0)
  // Delivery-invoice reconciliation — has the carrier fee for this order been
  // paid to Coliix? Flipped manually until the carrier API is integrated.
  paidToCarrier       Boolean            @default(false)
  paidToCarrierAt     DateTime?
  // Physical return verification after Coliix bounce-back.
  returnNote          String?
  returnVerifiedAt    DateTime?
  returnVerifiedById  String?
  // Which external system currently owns the shipment (e.g. "coliix"). Set
  // when the label is created; null for manual / not-yet-shipped orders.
  trackingProvider    String?
  // Poller throttle — last time we asked the provider for a status update.
  lastTrackedAt       DateTime?
  // When this order has been rolled into another (duplicate customer, unshipped),
  // this points at the keeper. Set together with isArchived=true by mergeOrders.
  // Kept as a FK so "how many orders get merged" is a one-query stat.
  mergedIntoId        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  customer         Customer    @relation(fields: [customerId], references: [id])
  agent            User?       @relation("AgentOrders", fields: [agentId], references: [id])
  store            Store?      @relation(fields: [storeId], references: [id])
  returnVerifiedBy User?       @relation("ReturnVerifier", fields: [returnVerifiedById], references: [id])
  mergedInto       Order?      @relation("OrderMerges", fields: [mergedIntoId], references: [id])
  mergedFrom       Order[]     @relation("OrderMerges")
  items            OrderItem[]
  logs             OrderLog[]
  messageLogs      MessageLog[]

  @@index([confirmationStatus])
  @@index([shippingStatus])
  @@index([agentId])
  @@index([customerId])
  @@index([createdAt])
  @@index([isArchived])
  @@index([mergedIntoId])
  @@index([confirmationStatus, createdAt])
  @@index([shippingStatus, createdAt])
  @@index([agentId, confirmationStatus])
  @@index([agentId, commissionPaid])
  @@index([agentId, deliveredAt])
  @@index([shippingStatus, paidToCarrier])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model OrderLog {
  id          String       @id @default(cuid())
  orderId     String
  type        OrderLogType @default(system)
  action      String
  performedBy String // display name or "System"
  userId      String?
  meta        Json?
  createdAt   DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([orderId, type])
}

// ─── Assignment & Shipping ────────────────────────────────────────────────────

model AssignmentRule {
  id        String   @id @default(cuid())
  name      String
  priority  Int      @default(0)
  cityMatch String?
  agentId   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ShippingCity {
  id       String  @id @default(cuid())
  name     String  @unique
  price    Decimal @db.Decimal(12, 2)
  zone     String?
  isActive Boolean @default(true)
}

// ─── Atelie ──────────────────────────────────────────────────────────────────

model AtelieEmployee {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  role        String
  baseSalary  Decimal  @default(0) @db.Decimal(12, 2) // weekly salary in MAD
  workingDays Int      @default(6) // divisor for daily rate
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())
  userId      String?  @unique

  user                 User?                 @relation("AtelieUser", fields: [userId], references: [id])
  attendance           WeeklyAttendance[]
  payments             SalaryPayment[]
  productionRunWorkers ProductionRunWorker[]
}

model WeeklyAttendance {
  id           String   @id @default(cuid())
  employeeId   String
  weekStart    DateTime // Monday 00:00 UTC of the week
  daysMask     Int      @default(0) // full-day mask — bit 0=Mon … bit 6=Sun
  halfDaysMask Int      @default(0) // half-day mask — same bit layout; mutually exclusive with daysMask
  daysWorked   Float    @default(0) // full + half * 0.5 (denormalized for fast salary calc)
  notes        String?
  recordedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   AtelieEmployee @relation(fields: [employeeId], references: [id])
  recordedBy User?          @relation("AttendanceRecorder", fields: [recordedById], references: [id])

  @@unique([employeeId, weekStart])
  @@index([weekStart])
}

model SalaryPayment {
  id         String    @id @default(cuid())
  employeeId String
  weekStart  DateTime // matches WeeklyAttendance.weekStart
  amount     Decimal   @db.Decimal(12, 2) // daysWorked × (baseSalary / workingDays)
  paidAmount Decimal   @default(0) @db.Decimal(12, 2)
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  paidById   String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee AtelieEmployee @relation(fields: [employeeId], references: [id])
  paidBy   User?          @relation("SalaryPayer", fields: [paidById], references: [id])

  @@unique([employeeId, weekStart])
  @@index([employeeId])
}

// ─── Atelie — Raw materials ───────────────────────────────────────────────────

enum MaterialCategory {
  fabric
  accessory
  needle
  thread
  other
}

enum MaterialUnit {
  meter
  piece
  kilogram
  spool
  box
}

model AtelieMaterial {
  id                String           @id @default(cuid())
  name              String
  category          MaterialCategory
  unit              MaterialUnit
  stock             Float            @default(0)
  lowStockThreshold Float            @default(0)
  unitCost          Decimal?         @db.Decimal(12, 2)
  supplier          String?
  notes             String?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  movements              MaterialMovement[]
  productTestAccessories ProductTestAccessory[]
  productionConsumptions ProductionConsumption[]

  @@index([category])
}

enum MaterialMovementType {
  in
  out
  adjustment
}

model MaterialMovement {
  id         String               @id @default(cuid())
  materialId String
  type       MaterialMovementType
  quantity   Float // always positive; `type` dictates sign applied to stock
  reason     String?
  userId     String?
  createdAt  DateTime             @default(now())

  material              AtelieMaterial         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  productionConsumption ProductionConsumption?

  @@index([materialId, createdAt])
}

// ─── Atelie — Fabric rolls & production runs ─────────────────────────────────

enum ProductionRunStatus {
  draft
  active
  finished
  cancelled
}

enum ConsumptionSourceType {
  fabric_roll
  accessory
}

model FabricType {
  id        String   @id @default(cuid())
  name      String   @unique
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rolls       FabricRoll[]
  testFabrics ProductTestFabric[]
  runFabrics  ProductionRunFabric[]
}

model FabricRoll {
  id               String   @id @default(cuid())
  fabricTypeId     String
  color            String
  widthCm          Float?
  initialLength    Float
  remainingLength  Float
  unitCostPerMeter Decimal  @db.Decimal(12, 2)
  purchaseDate     DateTime
  supplier         String?
  reference        String?
  notes            String?
  isDepleted       Boolean  @default(false)
  expenseId        String?  @unique
  createdAt        DateTime @default(now())

  fabricType   FabricType              @relation(fields: [fabricTypeId], references: [id])
  expense      Expense?                @relation(fields: [expenseId], references: [id])
  consumptions ProductionConsumption[]

  @@index([fabricTypeId, color])
  @@index([isDepleted])
}

enum SampleStatus {
  draft
  tested
  approved
  archived
}

model ProductTest {
  id                    String       @id @default(cuid())
  name                  String
  productId             String?
  videoUrl              String?
  // Long-form description shown to admins/buyers — separate from internal
  // `notes` (which can stay private). HTML stripped on save in the service.
  description           String?
  // Sample lifecycle. `approved` is the gate that unlocks creating a
  // ProductionRun from this sample.
  status                SampleStatus @default(draft)
  approvedAt            DateTime?
  approvedById          String?

  // Cost-calc inputs. Fees are per-piece overrides on the sample (a
  // YouCan / fulfillment fee can vary per garment). Markup feeds
  // `suggestedPrice`. The service recomputes `estimatedCostPerPiece` and
  // `suggestedPrice` on every save so they're always current.
  laborMadPerPiece      Decimal?     @db.Decimal(12, 2)
  confirmationFee       Decimal?     @db.Decimal(12, 2)
  deliveryFee           Decimal?     @db.Decimal(12, 2)
  markupPercent         Decimal?     @db.Decimal(5, 2)
  suggestedPrice        Decimal?     @db.Decimal(12, 2)

  estimatedCostPerPiece Decimal?     @db.Decimal(12, 2)
  notes                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  product     Product?               @relation(fields: [productId], references: [id])
  approvedBy  User?                  @relation("SampleApprover", fields: [approvedById], references: [id])
  fabrics     ProductTestFabric[]
  sizes       ProductTestSize[]
  accessories ProductTestAccessory[]
  photos      ProductTestPhoto[]
  runs        ProductionRun[]

  @@index([status, createdAt])
}

model ProductTestPhoto {
  id        String   @id @default(cuid())
  testId    String
  url       String
  caption   String?
  // Fractional position so reorders never need a backfill update of the
  // entire list — same trick used by AtelieTask.position.
  position  Float    @default(0)
  createdAt DateTime @default(now())

  test ProductTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, position])
}

model ProductTestFabric {
  id           String @id @default(cuid())
  testId       String
  fabricTypeId String
  role         String

  test       ProductTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  fabricType FabricType  @relation(fields: [fabricTypeId], references: [id])

  @@unique([testId, fabricTypeId, role])
}

model ProductTestSize {
  id            String @id @default(cuid())
  testId        String
  size          String
  tracingMeters Float

  test ProductTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, size])
}

model ProductTestAccessory {
  id               String   @id @default(cuid())
  testId           String
  materialId       String
  quantityPerPiece Float
  // Snapshot the material's unit cost at the moment the accessory was
  // added to the sample, so later AtelieMaterial price changes don't
  // retroactively rewrite the sample's estimated cost. Falls back to
  // material.unitCost in the calculator when null (legacy rows).
  unitCostSnapshot Decimal? @db.Decimal(12, 2)

  test     ProductTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  material AtelieMaterial @relation(fields: [materialId], references: [id])

  @@unique([testId, materialId])
}

model ProductionRun {
  id             String              @id @default(cuid())
  reference      String              @unique
  testId         String?
  productId      String?
  status         ProductionRunStatus @default(draft)
  startDate      DateTime
  endDate        DateTime?
  expectedPieces Int                 @default(0)
  actualPieces   Int                 @default(0)
  materialsCost  Decimal             @default(0) @db.Decimal(12, 2)
  laborCost      Decimal             @default(0) @db.Decimal(12, 2)
  totalCost      Decimal             @default(0) @db.Decimal(12, 2)
  costPerPiece   Decimal             @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  test         ProductTest?            @relation(fields: [testId], references: [id])
  product      Product?                @relation(fields: [productId], references: [id])
  fabrics      ProductionRunFabric[]
  sizes        ProductionRunSize[]
  consumptions ProductionConsumption[]
  workers      ProductionRunWorker[]

  @@index([status, startDate])
}

model ProductionRunFabric {
  id           String @id @default(cuid())
  runId        String
  fabricTypeId String
  role         String

  run        ProductionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fabricType FabricType    @relation(fields: [fabricTypeId], references: [id])

  @@unique([runId, fabricTypeId, role])
}

model ProductionRunSize {
  id             String  @id @default(cuid())
  runId          String
  size           String
  tracingMeters  Float
  expectedPieces Int
  actualPieces   Int     @default(0)
  variantId      String?

  run     ProductionRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([runId, size])
}

model ProductionConsumption {
  id           String                @id @default(cuid())
  runId        String
  sourceType   ConsumptionSourceType
  fabricRollId String?
  materialId   String?
  movementId   String?               @unique
  quantity     Float
  unitCost     Decimal               @db.Decimal(12, 2)
  createdAt    DateTime              @default(now())
  createdById  String?

  run        ProductionRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  fabricRoll FabricRoll?       @relation(fields: [fabricRollId], references: [id])
  material   AtelieMaterial?   @relation(fields: [materialId], references: [id])
  movement   MaterialMovement? @relation(fields: [movementId], references: [id])

  @@index([runId])
}

model ProductionRunWorker {
  id         String  @id @default(cuid())
  runId      String
  employeeId String
  role       String?

  run      ProductionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  employee AtelieEmployee @relation(fields: [employeeId], references: [id])

  @@unique([runId, employeeId])
}

// ─── Atelie — Team Tasks ──────────────────────────────────────────────────────

enum AtelieTaskStatus {
  backlog
  processing
  done
  forgotten
  incomplete
}

enum AtelieTaskVisibility {
  private
  shared
}

model AtelieTask {
  id               String               @id @default(cuid())
  ownerId          String
  title            String
  description      String?
  status           AtelieTaskStatus     @default(backlog)
  visibility       AtelieTaskVisibility @default(private)
  color            String?
  position         Float // fractional indexing within column
  incompleteReason String?
  dueAt            DateTime?
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  owner       User                   @relation("TaskOwner", fields: [ownerId], references: [id])
  comments    AtelieTaskComment[]
  attachments AtelieTaskAttachment[]
  hides       AtelieTaskHide[]

  @@index([ownerId, status, position])
  @@index([visibility, status, position])
}

model AtelieTaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  task   AtelieTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User       @relation("TaskCommenter", fields: [authorId], references: [id])

  @@index([taskId, createdAt])
}

model AtelieTaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  uploadedBy String
  fileUrl    String
  fileName   String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  task AtelieTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model AtelieTaskHide {
  userId    String
  taskId    String
  createdAt DateTime @default(now())

  task AtelieTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([userId, taskId])
  @@index([taskId])
}

// ─── Settings & Config ────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Analytics — Expenses ────────────────────────────────────────────────────
// Free-form running log of money spent (ads, rent, packaging, salaries paid
// outside atelie, anything). Shown in the Analytics → Expenses tab and
// aggregated into the Profit tab.
model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime // user-selected date of the expense (not createdAt)
  fileUrl     String? // optional invoice / screenshot upload
  addedById   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addedBy    User?       @relation("ExpenseAuthor", fields: [addedById], references: [id])
  fabricRoll FabricRoll?

  @@index([date])
}

// ─── Money — Commission payments ─────────────────────────────────────────────
// Ledger of disbursements to agents. `amount` is what was actually paid out
// (which may cover many orders); `orderIds` stores which orders the payment
// cleared so we can mark `Order.commissionPaid = true` atomically.
model CommissionPayment {
  id           String    @id @default(cuid())
  agentId      String
  amount       Decimal   @db.Decimal(12, 2)
  periodFrom   DateTime?
  periodTo     DateTime?
  paidAt       DateTime  @default(now())
  notes        String?
  fileUrl      String?
  orderIds     String[] // order IDs cleared by this payment
  recordedById String?
  createdAt    DateTime  @default(now())

  agent      User  @relation("CommissionAgent", fields: [agentId], references: [id])
  recordedBy User? @relation("CommissionRecorder", fields: [recordedById], references: [id])

  @@index([agentId])
  @@index([paidAt])
}

model CommissionRule {
  id        String   @id @default(cuid())
  agentId   String
  type      String
  // Decimal works for both flat-MAD rules ("50.00") and percent rules
  // ("5.00" meaning 5%). The interpretation lives in `type`.
  value     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  agent User @relation(fields: [agentId], references: [id])
}

// ─── Notifications ───────────────────────────────────────────────────────────
// One row per recipient — admin-targeted events create one row per admin so
// each user has an independent read state. `href` is the optional client route
// the TopBar bell should navigate to when the notification is clicked.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  kind      String // e.g. "order_assigned" | "order_confirmed" | "system"
  title     String
  body      String?
  href      String?
  orderId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ─── WhatsApp automation ────────────────────────────────────────────────────
// Client & agent notifications sent automatically on order status transitions
// and commission payouts. Every `MessageTemplate` has a unique trigger; the
// dispatcher fans out to one `MessageLog` row per recipient, enqueued into the
// Bull `whatsappQueue` and pushed through Evolution API per-agent sessions.
enum AutomationTrigger {
  confirmation_confirmed
  confirmation_cancelled
  confirmation_unreachable
  shipping_label_created
  shipping_picked_up
  shipping_in_transit
  shipping_out_for_delivery
  shipping_delivered
  shipping_returned
  shipping_return_validated
  commission_paid
}

enum WhatsAppSessionStatus {
  disconnected
  connecting
  connected
  error
}

enum MessageLogStatus {
  queued
  sending
  sent
  delivered
  failed
  dead // gave up after Bull exhausted retries — shown in DLQ, requeue-able
}

enum WhatsAppThreadStatus {
  open
  closed
  snoozed
}

enum WhatsAppMessageDirection {
  in
  out
}

model MessageTemplate {
  id          String            @id @default(cuid())
  trigger     AutomationTrigger @unique
  enabled     Boolean           @default(false)
  body        String
  updatedById String?
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())

  updatedBy User?            @relation("TemplateUpdater", fields: [updatedById], references: [id])
  rules     AutomationRule[]
}

// A rule layers condition-based routing on top of a template. Multiple rules
// can fire for the same trigger with different conditions and priorities —
// the dispatcher loads enabled rules for a trigger ordered by priority desc
// and fires the first that matches (`overlap='first'`) or all matches
// (`overlap='all'`). Conditions are a whitelisted JSON shape evaluated by
// conditionEvaluator.ts (no arbitrary code).
model AutomationRule {
  id          String            @id @default(cuid())
  trigger     AutomationTrigger
  name        String
  priority    Int               @default(0)
  enabled     Boolean           @default(true)
  overlap     String            @default("first") // "first" | "all"
  conditions  Json              @default("{}")
  templateId  String
  sendFromSystem Boolean        @default(false)
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  template  MessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("RuleAuthor", fields: [createdById], references: [id])
  logs      MessageLog[]

  @@index([trigger, enabled, priority])
}

model WhatsAppSession {
  id            String                @id @default(cuid())
  userId        String?               @unique
  instanceName  String                @unique
  status        WhatsAppSessionStatus @default(disconnected)
  phoneNumber   String?
  lastHeartbeat DateTime?
  connectedAt   DateTime?
  createdAt     DateTime              @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model MessageLog {
  id             String            @id @default(cuid())
  trigger        AutomationTrigger
  ruleId         String?
  orderId        String?
  agentId        String?
  recipientPhone String
  body           String
  status         MessageLogStatus  @default(queued)
  providerId     String?
  error          String?
  dedupeKey      String            @unique
  attempts       Int               @default(0)
  createdAt      DateTime          @default(now())
  sentAt         DateTime?

  rule  AutomationRule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  order Order?           @relation(fields: [orderId], references: [id])
  agent User?            @relation("MessageLogAgent", fields: [agentId], references: [id])

  messages WhatsAppMessage[]

  @@index([status, createdAt])
  @@index([orderId])
  @@index([trigger, createdAt])
}

// Two-way inbox. One thread per customer ↔ agent-session pairing. Inbound
// messages land here; automation-driven outbound messages are appended as
// direction='out' so the agent sees the full history inline with their
// manual replies.
model WhatsAppThread {
  id               String               @id @default(cuid())
  customerId       String?
  assignedAgentId  String?
  customerPhone    String
  lastMessageAt    DateTime             @default(now())
  unreadCount      Int                  @default(0)
  status           WhatsAppThreadStatus @default(open)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  customer      Customer? @relation(fields: [customerId], references: [id])
  assignedAgent User?     @relation("ThreadAssignee", fields: [assignedAgentId], references: [id])
  messages      WhatsAppMessage[]

  @@unique([customerPhone, assignedAgentId])
  @@index([assignedAgentId, status, lastMessageAt])
  @@index([customerId])
}

model WhatsAppMessage {
  id           String                    @id @default(cuid())
  threadId     String
  direction    WhatsAppMessageDirection
  body         String
  mediaUrl     String?
  mediaType    String?                   // 'image' | 'audio' | 'video' | 'sticker' | 'document'
  mediaMime    String?
  fromPhone    String
  toPhone      String
  providerId   String?
  messageLogId String?
  authorUserId String?
  readAt       DateTime?
  createdAt    DateTime                  @default(now())

  thread     WhatsAppThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messageLog MessageLog?    @relation(fields: [messageLogId], references: [id], onDelete: SetNull)
  author     User?          @relation("MessageAuthor", fields: [authorUserId], references: [id])

  @@index([threadId, createdAt])
  @@index([providerId])
}

// ─── Shipping status groups (Call Center pill grouping) ─────────────────────

// Admin-managed buckets that roll up the long ShippingStatus enum into a
// handful of named tabs ("Active", "Issues", "Delivered", …) on the Call
// Center page. `statusKeys` holds the raw enum strings so adding a new
// ShippingStatus value never requires a schema change. Statuses not claimed
// by any group automatically surface in the frontend's "Other" tab.
model ShippingStatusGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String?
  statusKeys  String[]
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("StatusGroupAuthor", fields: [createdById], references: [id])

  @@index([position])
}

// ─── Broadcasts (admin push notifications) ──────────────────────────────────

// Admin-pushed announcements aimed at one or more agents. Two kinds:
//  - POPUP: blocking modal that re-shows on every page load until the agent
//    clicks OK. The OK click counts as "read" and the popup never returns
//    for that agent.
//  - BAR: sticky banner at the top of the Call Center page. Agents cannot
//    dismiss; only the admin can flip `isActive` to false to retire it.
// Each broadcast can carry text + optional image + optional clickable link.
// Per-recipient rows track delivery / acknowledgement / link clicks so the
// admin can audit who actually saw the message.
enum BroadcastKind {
  POPUP
  BAR
}

model Broadcast {
  id            String        @id @default(cuid())
  kind          BroadcastKind
  title         String
  body          String?
  imageUrl      String?
  linkUrl       String?
  isActive      Boolean       @default(true)
  createdById   String
  createdBy     User          @relation("BroadcastAuthor", fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  deactivatedAt DateTime?

  recipients BroadcastRecipient[]

  @@index([kind, isActive, createdAt])
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("BroadcastTarget", fields: [userId], references: [id], onDelete: Cascade)
  deliveredAt DateTime?
  ackedAt     DateTime?
  clickedAt   DateTime?
  clickCount  Int       @default(0)

  @@unique([broadcastId, userId])
  @@index([userId, ackedAt])
}
